<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="0dp">

        <!-- Banner / Logo -->
        <ImageView
            android:id="@+id/imageBanner"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:src="@drawable/banner_hamburguer"
            android:contentDescription="Logo HamburgueriaZ" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Título -->
            <TextView
                android:id="@+id/textFacaSeuPedido"
                style="@style/EstiloTexto"
                android:text="Faça seu pedido!" />

            <!-- Campo Nome -->
            <EditText
                android:id="@+id/editTextNome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nome"
                android:inputType="textPersonName"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/colorPrimary" />

            <!-- Adicionais -->
            <CheckBox
                android:id="@+id/checkBoxBacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bacon  (+R$ 2,00)"
                android:textSize="15sp"
                android:buttonTint="@color/colorPrimary"
                android:layout_marginBottom="4dp" />

            <CheckBox
                android:id="@+id/checkBoxQueijo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Queijo  (+R$ 2,00)"
                android:textSize="15sp"
                android:buttonTint="@color/colorPrimary"
                android:layout_marginBottom="4dp" />

            <CheckBox
                android:id="@+id/checkBoxOnionRings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Onion Rings  (+R$ 3,00)"
                android:textSize="15sp"
                android:buttonTint="@color/colorPrimary"
                android:layout_marginBottom="8dp" />

            <!-- Quantidade -->
            <TextView
                android:id="@+id/textQuantidadeLabel"
                style="@style/EstiloTexto"
                android:text="Quantidade" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/buttonSubtrair"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="-"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/colorPrimary"
                    android:onClick="subtrair"
                    android:padding="0dp" />

                <TextView
                    android:id="@+id/textQuantidade"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="#333333" />

                <Button
                    android:id="@+id/buttonSomar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="+"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/colorPrimary"
                    android:onClick="somar"
                    android:padding="0dp" />

            </LinearLayout>

            <!-- Resumo do pedido -->
            <TextView
                android:id="@+id/textResumoPedidoLabel"
                style="@style/EstiloTexto"
                android:text="Resumo do pedido" />

            <TextView
                android:id="@+id/textResumoPedido"
                style="@style/EstiloTexto"
                android:text="R$ 0"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textColor="#555555" />

            <!-- Botão Fazer Pedido -->
            <Button
                android:id="@+id/buttonEnviarPedido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FAZER PEDIDO"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/colorPrimary"
                android:onClick="enviarPedido"
                android:layout_marginTop="12dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
